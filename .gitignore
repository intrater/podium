# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# But DO commit the example template — that's the contract for new contributors.
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# podium-specific
# Local Claude Code settings (per-machine, not shared)
.claude/settings.local.json
# Particle docs (fetched locally; not committed because they're not ours)
docs/particle/
# Supabase seed (contains real user UUIDs — local only; commit seed.sql.example template)
supabase/seed.sql
