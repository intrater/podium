# ──────────────────────────────────────────────────────────────────────────
# Podium env vars — local development template.
#
# Copy this file to `.env.local` (gitignored) and fill in real values from
# your dashboards. See docs/solutions/2026-05-09-env-and-secrets-setup.md
# for the full setup walkthrough.
#
# Discipline:
# - Only NEXT_PUBLIC_* variables ever reach the browser. Everything else is
#   server-only and validated as such by lib/env.ts.
# - Never commit `.env.local`. Never paste values into chat.
# - For Vercel deployments, mirror these into the project's
#   Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────
# From your Supabase project's Settings → API. Use the *staging* project's
# values for local development; the *prod* project's values go into Vercel
# Production environment variables.

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Treat as ultra-sensitive — bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Used by lib/auth/stub-jwt.ts to mint synthetic JWTs in v1
# stub-auth mode so the anon-key client exercises RLS as if real auth were
# active. Generate via Supabase dashboard → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# ─── Anthropic ────────────────────────────────────────────────────────────
# From console.anthropic.com → Settings → API Keys. Make sure billing is
# enabled on the workspace.
ANTHROPIC_API_KEY=

# ─── Particle ─────────────────────────────────────────────────────────────
# From platform.particle.pro. Confirm Starter tier ($10 starter credit)
# AND payment method on file before running the first non-dev-mode seed —
# Starter does NOT support overage; credit exhaustion produces a hard 402
# block until the next billing cycle.
PARTICLE_API_KEY=

# ─── Podium-specific ──────────────────────────────────────────────────────

# Random secret protecting the manual /api/ingest "Run now" endpoint.
# Generate with `openssl rand -base64 32` or any high-entropy method.
CRON_SECRET=

# The single hardcoded user UUID for v1 stub-auth mode. Generate with
# `uuidgen` (Mac) or any UUID v4 generator. This becomes the lone row in
# auth.users, seeded by scripts/seed-supabase.ts at deploy time.
PODIUM_USER_ID=

# Gates the daily ingest pipeline to a small subset of podcasts and a
# 1-day window — saves Particle credit during build/test. Default: true
# in dev, false in prod (set explicitly in Vercel Production env vars).
INGEST_DEV_MODE=true
